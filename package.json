{
  "name": "jpn-laws-mcp-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "version": "1.0.3",
  "scripts": {
    "prepare": "husky || true",
    "build": "bun run ./scripts/build.ts",
    "lint": "biome check .",
    "fmt": "biome check --write --unsafe .",
    "typecheck:core": "tsc --project tsconfig.core.json",
    "typecheck:tools": "tsc --project tsconfig.tools.json",
    "typecheck:types": "tsc --project tsconfig.types.json",
    "typecheck:server": "tsc --project tsconfig.server.json",
    "preinspector": "bun run build",
    "inspector": "mcp-inspector bun run ./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@modelcontextprotocol/inspector": "0.21.2",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "lint-staged": "17.0.6",
    "typescript": "6.0.3"
  }
}
